// AssetFlow — Enterprise Asset & Resource Management
// LOCK THIS AT HOUR 1. Do not change it after.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPT_HEAD
  EMPLOYEE // ← signup ALWAYS creates this. Only Admin promotes.
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
  RESOLVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditCycleStatus {
  OPEN
  CLOSED
}

enum AuditResult {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

// ─────────────────────────────────────────────────────────────
// MASTER DATA
// ─────────────────────────────────────────────────────────────

model Department {
  id       String         @id @default(cuid())
  name     String         @unique
  code     String         @unique
  status   EmployeeStatus @default(ACTIVE)

  headId   String?
  head     Employee?      @relation("DeptHead", fields: [headId], references: [id])

  employees    Employee[]    @relation("DeptMembers")
  assets       Asset[]
  allocations  Allocation[]

  createdAt DateTime @default(now())
}

model Employee {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         Role           @default(EMPLOYEE)
  status       EmployeeStatus @default(ACTIVE)

  departmentId String?
  department   Department?    @relation("DeptMembers", fields: [departmentId], references: [id])

  headsDepartments Department[]         @relation("DeptHead")
  allocations      Allocation[]         @relation("Holder")
  allocatedByMe    Allocation[]         @relation("AllocatedBy")
  bookings         Booking[]
  maintenanceRaised MaintenanceRequest[] @relation("RaisedBy")
  maintenanceApproved MaintenanceRequest[] @relation("ApprovedBy")
  auditCycles      AuditCycle[]         @relation("Auditors")
  auditItems       AuditItem[]
  notifications    Notification[]
  activityLogs     ActivityLog[]

  createdAt DateTime @default(now())
}

model AssetCategory {
  id            String  @id @default(cuid())
  name          String  @unique
  // Optional category-specific fields, e.g. { "warrantyMonths": 24 }
  customFields  Json?
  assets        Asset[]

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// ASSETS
// ─────────────────────────────────────────────────────────────

model Asset {
  id              String         @id @default(cuid())
  assetTag        String         @unique // AF-0001 — this is what the QR encodes
  name            String
  serialNumber    String?        @unique
  acquisitionDate DateTime
  acquisitionCost Decimal        @db.Decimal(12, 2)
  condition       AssetCondition @default(GOOD)
  location        String
  photoUrl        String?
  isBookable      Boolean        @default(false) // shared resource: rooms, vehicles
  status          AssetStatus    @default(AVAILABLE)

  categoryId   String
  category     AssetCategory @relation(fields: [categoryId], references: [id])
  departmentId String?
  department   Department?   @relation(fields: [departmentId], references: [id])

  allocations  Allocation[]
  bookings     Booking[]
  maintenance  MaintenanceRequest[]
  auditItems   AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([categoryId])
}

// ─────────────────────────────────────────────────────────────
// ALLOCATION + TRANSFER
// ─────────────────────────────────────────────────────────────

model Allocation {
  id                 String    @id @default(cuid())
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id])

  holderId           String?
  holder             Employee? @relation("Holder", fields: [holderId], references: [id])
  departmentId       String?
  department         Department? @relation(fields: [departmentId], references: [id])

  allocatedById      String
  allocatedBy        Employee  @relation("AllocatedBy", fields: [allocatedById], references: [id])

  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime? // NULL = currently held. See the partial unique index.
  checkInNotes       String?
  returnCondition    AssetCondition?

  transfers TransferRequest[]

  // ⚠️ The double-allocation rule is enforced in constraints.sql, NOT here.
  // Prisma can't express partial unique indexes.
  @@index([assetId, returnedAt])
  @@index([expectedReturnDate])
}

model TransferRequest {
  id            String         @id @default(cuid())
  allocationId  String
  allocation    Allocation     @relation(fields: [allocationId], references: [id])

  requestedById String
  requestedForId String
  approvedById  String?

  status        TransferStatus @default(REQUESTED)
  reason        String?

  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?
}

// ─────────────────────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────────────────────

model Booking {
  id         String        @id @default(cuid())
  assetId    String
  asset      Asset         @relation(fields: [assetId], references: [id])
  bookedById String
  bookedBy   Employee      @relation(fields: [bookedById], references: [id])

  startTime  DateTime      @db.Timestamptz
  endTime    DateTime      @db.Timestamptz
  purpose    String?
  status     BookingStatus @default(UPCOMING)

  createdAt  DateTime      @default(now())

  // ⚠️ Overlap prevention is a GiST exclusion constraint in constraints.sql.
  @@index([assetId, startTime, endTime])
}

// ─────────────────────────────────────────────────────────────
// MAINTENANCE
// ─────────────────────────────────────────────────────────────

model MaintenanceRequest {
  id          String            @id @default(cuid())
  assetId     String
  asset       Asset             @relation(fields: [assetId], references: [id])

  raisedById  String
  raisedBy    Employee          @relation("RaisedBy", fields: [raisedById], references: [id])
  approvedById String?
  approvedBy  Employee?         @relation("ApprovedBy", fields: [approvedById], references: [id])

  issue       String
  priority    Priority          @default(MEDIUM)
  photoUrl    String?
  status      MaintenanceStatus @default(PENDING)
  technician  String?
  resolution  String?

  createdAt   DateTime          @default(now())
  resolvedAt  DateTime?

  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// AUDIT
// ─────────────────────────────────────────────────────────────

model AuditCycle {
  id        String           @id @default(cuid())
  name      String
  scopeDept String?
  scopeLoc  String?
  startDate DateTime
  endDate   DateTime
  status    AuditCycleStatus @default(OPEN)

  auditors  Employee[]       @relation("Auditors")
  items     AuditItem[]

  closedAt  DateTime?
  createdAt DateTime         @default(now())
}

model AuditItem {
  id           String      @id @default(cuid())
  auditCycleId String
  auditCycle   AuditCycle  @relation(fields: [auditCycleId], references: [id])
  assetId      String
  asset        Asset       @relation(fields: [assetId], references: [id])

  result       AuditResult @default(PENDING)
  notes        String?
  auditedById  String?
  auditedBy    Employee?   @relation(fields: [auditedById], references: [id])
  auditedAt    DateTime?

  @@unique([auditCycleId, assetId])
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATIONS + ACTIVITY LOG
// ─────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  title      String
  body       String
  link       String?
  read       Boolean  @default(false)

  createdAt  DateTime @default(now())

  @@index([employeeId, read])
}

// Append-only. Never UPDATE or DELETE from this table.
model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      Employee? @relation(fields: [actorId], references: [id])

  action     String   // "ASSET_ALLOCATED", "BOOKING_CREATED", ...
  entityType String   // "Asset", "Booking", ...
  entityId   String
  before     Json?
  after      Json?

  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
